class SphereGeodesics:
    """
    Solve geodesic equations on S² properly
    
    Geodesic equations:
    d²θ/dt² - sin(θ)cos(θ)(dφ/dt)² = 0
    d²φ/dt² + 2cot(θ)(dθ/dt)(dφ/dt) = 0
    """
    
    def __init__(self, R=1.0):
        self.R = R  # sphere radius
    
    def geodesic_equations(self, t, y):
        """
        y = [θ, φ, dθ/dt, dφ/dt]
        
        Returns: dy/dt
        """
        theta, phi, theta_dot, phi_dot = y
        
        # Avoid singularity at poles
        epsilon = 1e-10
        sin_theta = np.sin(theta) if np.abs(np.sin(theta)) > epsilon else epsilon
        
        # d²θ/dt²
        theta_ddot = np.sin(theta) * np.cos(theta) * phi_dot**2
        
        # d²φ/dt²
        phi_ddot = -2 * (np.cos(theta) / sin_theta) * theta_dot * phi_dot
        
        return [theta_dot, phi_dot, theta_ddot, phi_ddot]
    
    def compute_geodesic(self, theta_i, phi_i, theta_f, phi_f, n_points=100):
        """
        Compute geodesic path from (θ_i,φ_i) to (θ_f,φ_f)
        
        Returns:
        --------
        theta_path, phi_path : arrays
            Geodesic coordinates
        """
        # Initial velocity direction (approximate)
        Delta_theta = theta_f - theta_i
        Delta_phi = phi_f - phi_i
        
        # Normalize to unit velocity on sphere
        v_mag = np.sqrt(Delta_theta**2 + (np.sin(theta_i) * Delta_phi)**2)
        if v_mag < 1e-10:
            # Same point
            return np.array([theta_i]), np.array([phi_i])
        
        theta_dot_0 = Delta_theta / v_mag
        phi_dot_0 = Delta_phi / (np.sin(theta_i) * v_mag) if np.abs(np.sin(theta_i)) > 1e-10 else 0
        
        # Initial conditions
        y0 = [theta_i, phi_i, theta_dot_0, phi_dot_0]
        
        # Time span (normalized)
        t_span = (0, v_mag)
        t_eval = np.linspace(0, v_mag, n_points)
        
        # Solve geodesic equation
        sol = solve_ivp(self.geodesic_equations, t_span, y0, 
                       t_eval=t_eval, method='RK45', rtol=1e-8)
        
        return sol.y[0], sol.y[1]  # theta, phi


class BerryMonopoleFixed:
    """
    Berry monopole with CORRECTED path integral
    """
    
    def __init__(self, g=0.5, theta_0=np.pi, R=1.0):
        self.g = g
        self.theta_0 = theta_0
        self.R = R
        self.geodesics = SphereGeodesics(R=R)
        
    def A_phi(self, theta):
        """Berry connection A_φ = g(cos θ - cos θ₀)"""
        return self.g * (np.cos(theta) - np.cos(self.theta_0))
    
    def holonomy_geodesic(self, theta_i, phi_i, theta_j, phi_j):
        """
        Compute holonomy along GEODESIC (not straight line!)
        
        γ = ∫_geodesic A_φ dφ
        """
        # Compute geodesic path
        theta_path, phi_path = self.geodesics.compute_geodesic(
            theta_i, phi_i, theta_j, phi_j, n_points=200
        )
        
        # Berry connection along path
        A = self.A_phi(theta_path)
        
        # Integrate A_φ dφ
        dphi = np.gradient(phi_path)
        from scipy.integrate import trapezoid
        gamma = trapezoid(A, phi_path)
        
        return np.exp(1j * gamma)
    
    def F_ij_magnitude_corrected(self, theta_i, phi_i, theta_j, phi_j):
        """Corrected |F_ij| from geodesic holonomy"""
        W = self.holonomy_geodesic(theta_i, phi_i, theta_j, phi_j)
        return np.abs(W)


