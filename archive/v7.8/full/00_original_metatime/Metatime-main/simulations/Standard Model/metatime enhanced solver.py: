class RGFlowSolver:
    """
    Derive α_f exponents from RG beta functions
    
    Anomalous dimension: γ_m(g) determines mass running
    β-function: β(g) = dg/d(ln μ)
    
    Connection: α_f = 1/(1 + γ_m)
    """
    
    def __init__(self):
        pass
    
    def beta_QED(self, alpha):
        """
        QED beta function (1-loop)
        β(α) = (2/3π) α²
        """
        return (2/(3*np.pi)) * alpha**2
    
    def beta_QCD(self, alpha_s, N_f=3):
        """
        QCD beta function (1-loop)
        β(α_s) = -(11 - 2N_f/3) α_s²/(4π)
        """
        b0 = 11 - 2*N_f/3
        return -b0 * alpha_s**2 / (4*np.pi)
    
    def gamma_m_QED(self, alpha):
        """
        Anomalous dimension for leptons (QED)
        γ_m = -3α/(4π)
        """
        return -3 * alpha / (4*np.pi)
    
    def gamma_m_QCD(self, alpha_s):
        """
        Anomalous dimension for quarks (QCD, 1-loop)
        γ_m = -α_s/π
        """
        return -alpha_s / np.pi
    
    def derive_alpha_f(self, family='lepton'):
        """
        Derive α_f exponent for family from RG
        
        α_f = 1/β where β = 1/2 (1 + γ_m)
        """
        if family == 'lepton':
            # QED coupling at MZ
            alpha_em = 1/128
            gamma_m = self.gamma_m_QED(alpha_em)
            
        elif family == 'light_quark':
            # QCD coupling at 1 GeV
            alpha_s = 0.5
            gamma_m = self.gamma_m_QCD(alpha_s)
            
        elif family == 'heavy_quark':
            # QCD coupling at M_Z
            alpha_s = 0.118
            gamma_m = self.gamma_m_QCD(alpha_s)
            
        else:
            gamma_m = 0
        
        # β exponent from dimensional reduction
        beta = 0.5 * (1 + gamma_m)
        
        # α = 1/β
        alpha_f = 1.0 / beta if beta > 0 else 2.0
        
        return alpha_f, gamma_m
    
    def RG_exponents_table(self):
        """Generate table of derived α_f"""
        families = ['lepton', 'light_quark', 'heavy_quark']
        
        results = {}
        for fam in families:
            alpha_f, gamma_m = self.derive_alpha_f(fam)
            results[fam] = {'alpha_f': alpha_f, 'gamma_m': gamma_m}
        
        return results


